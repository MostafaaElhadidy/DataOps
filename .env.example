# ── LLM (vLLM or Ollama on Lightning AI, OpenAI-compatible endpoint) ──────────
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=not-needed
# Heavy reasoning agents (RCA, Lineage, Runbook)
LLM_MODEL_HEAVY=qwen2.5:32b
# Standard agents (Monitoring, Triage, Remediation, Validation, Postmortem)
LLM_MODEL_STANDARD=qwen2.5:14b

# ── Data Pipeline ─────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=pipeline-events

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pipeline
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=pipeline_secret

# ── Monitoring ────────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_BASE_URL=http://localhost:8080
AIRFLOW_USER=airflow
AIRFLOW_PASSWORD=airflow

# ── RAG / Qdrant ──────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=runbooks

# ── Web Search ────────────────────────────────────────────────────────────────
TAVILY_API_KEY=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

# ── Observability (LangSmith — optional) ──────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=aiops-platform

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# ── Safety ────────────────────────────────────────────────────────────────────
MAX_RETRIES=3
DRY_RUN=false
HITL_ENABLED=true

# ── Paths ─────────────────────────────────────────────────────────────────────
REPORTS_DIR=reports
INCIDENTS_DIR=incidents
